# Server
PORT=8787
AUTH_TOKEN=change-me

# LLM
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=claude-haiku-4-5

# Policies
POLICY_SOURCES=file:///etc/cc-tool-gate/policies
POLICY_POLL_MS=60000

# Audit logs (local)
LOGS_DIR=./logs
HOSTNAME=                              # blank = use os.hostname()

# Decision cache
CACHE_TTL_MS=300000
CACHE_MAX=2000

# === Audit log storage backend ===
# none = local JSONL only (default)
# r2   = Cloudflare R2
# s3   = AWS S3 (or any S3-compatible service via S3_ENDPOINT)
STORAGE_BACKEND=none
UPLOAD_POLL_MS=30000

# --- R2 (required when STORAGE_BACKEND=r2) ---
R2_ENDPOINT=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# --- S3 (required when STORAGE_BACKEND=s3) ---
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_SESSION_TOKEN=                      # optional, for AWS STS temp creds
S3_ENDPOINT=                           # optional, for LocalStack/MinIO
