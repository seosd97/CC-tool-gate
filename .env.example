# Server
PORT=8787
HOST=127.0.0.1                         # 0.0.0.0 to expose on LAN
AUTH_TOKEN=change-me

# LLM
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=claude-haiku-4-5

# Policies (only file:// is supported)
POLICY_SOURCES=file:///etc/cc-tool-gate/policies

# Audit logs (local JSONL, one file per UTC day: audit-YYYY-MM-DD.jsonl)
LOGS_DIR=./logs

# Decision cache
CACHE_TTL_MS=300000
CACHE_MAX=2000

# Per-session_id rate limit; 0 disables
RATE_LIMIT_PER_MIN=600
