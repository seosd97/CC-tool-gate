# Server
PORT=8787
AUTH_TOKEN=change-me

# LLM
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=claude-haiku-4-5

# Policies
POLICY_SOURCES=file:///etc/cc-tool-gate/policies
POLICY_POLL_MS=60000

# Audit logs (local)
LOGS_DIR=./logs
HOSTNAME=                              # blank = use os.hostname()

# Decision cache
CACHE_TTL_MS=300000
CACHE_MAX=2000

# R2 audit log upload (all four required to enable; missing => local-only)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=cc-tool-gate-audit-dev
R2_POLL_MS=30000
