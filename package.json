{
  "name": "cc-tool-gate",
  "version": "0.1.0",
  "description": "LLM-powered permission gate for Claude Code's PreToolUse hook",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "license": "MIT",
  "author": "seosd97",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seosd97/CC-tool-gate.git"
  },
  "keywords": [
    "claude-code",
    "claude",
    "anthropic",
    "permission",
    "hook",
    "agent",
    "bun",
    "hono"
  ],
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --hot src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint src/ tests/",
    "lint:fix": "biome lint --write src/ tests/",
    "format": "biome format --write src/ tests/",
    "check": "biome check src/ tests/",
    "check:fix": "biome check --write src/ tests/"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/bun": "latest",
    "typescript": "^5"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "gray-matter": "^4.0.3",
    "hono": "^4.12.14",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  }
}
